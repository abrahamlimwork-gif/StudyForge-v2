rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * StudyForge Security Rules
     *
     * Core Philosophy:
     * This ruleset enforces a strict ownership model based on hierarchical pathing. 
     * Security is anchored to the 'facilitatorId' present in the document paths, 
     * ensuring that users can only access and manage data within their own tree.
     *
     * Data Structure:
     * All application data is organized under a user-centric hierarchy:
     * /users/{facilitatorId}/sessions/{sessionId}/...
     *
     * Demo Mode:
     * Includes a top-level 'public_sessions' collection for shared testing environments.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for Public Sessions (Demo/Testing).
     * @path /public_sessions/{sessionId}
     */
    match /public_sessions/{sessionId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false; // Restricted for safety
    }

    /**
     * @description Rules for Session documents, owned by a facilitator.
     * @path /users/{facilitatorId}/sessions/{sessionId}
     */
    match /users/{facilitatorId}/sessions/{sessionId} {
      allow get, list: if isOwner(facilitatorId);
      
      allow create: if isOwner(facilitatorId) 
        && request.resource.data.facilitatorId == facilitatorId;
      
      allow update: if isExistingOwner(facilitatorId) 
        && request.resource.data.facilitatorId == resource.data.facilitatorId;
      
      allow delete: if isExistingOwner(facilitatorId);

      /**
       * @description Rules for AI-generated LessonPrompts within a session.
       */
      match /lessonPrompts/{lessonPromptId} {
        allow get, list: if isOwner(facilitatorId);

        allow create: if isOwner(facilitatorId)
          && request.resource.data.facilitatorId == facilitatorId
          && request.resource.data.sessionId == sessionId;

        allow update: if isExistingOwner(facilitatorId)
          && request.resource.data.facilitatorId == resource.data.facilitatorId
          && request.resource.data.sessionId == resource.data.sessionId;

        allow delete: if isExistingOwner(facilitatorId);
      }
    }

    // --- Global Deny-All ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}